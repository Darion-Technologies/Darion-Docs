{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "src/supabase/types/dist",
    "rootDir": "src/supabase"
  },
  "include": ["src/supabase/**/*.ts"],
  "exclude": ["src/supabase/**/*.mjs"]
}
