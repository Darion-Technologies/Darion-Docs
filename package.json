{
  "name": "darion-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev . --mode development",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "supabase:start": "supabase start",
    "supabase:db:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > src/supabase/database.types.ts",
    "supabase:types:remote": "supabase gen types typescript --project-id llflitxgfwrkutyeyirfa --schema rbac > src/supabase/database.types.ts",
    "types:check": "tsc -p tsconfig.supabase.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitepress": "^1.6.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1"
  }
}
